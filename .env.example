# ---------------------------------------------------------------------------
# Copy to `.env` for local development. NEVER commit your real .env file.
# Azure App Service: set these as App Settings, not in a checked-in file.
# ---------------------------------------------------------------------------

# Server
PORT=8080
LOG_LEVEL=info                  # debug | info | warn | error

# --- Perplexity (existing) -------------------------------------------------
PERPLEXITY_API_KEY=
PERPLEXITY_MODEL=sonar

# --- GitHub: PAT (default, simplest path) ---------------------------------
# Used as the fallback when no per-user OAuth token is stored. Create at
# https://github.com/settings/tokens — for a fine-grained token, grant the
# read-only scopes you actually need (Contents, Issues, Pull requests, etc.).
GITHUB_TOKEN=

# --- GitHub: OAuth (production multi-user path) ---------------------------
# Register an OAuth App or GitHub App at https://github.com/settings/developers.
# Set the Authorization callback URL to ${PUBLIC_ORIGIN}/auth/github/callback.
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://localhost:8080/auth/github/callback

# Where to persist refresh tokens between restarts during local dev.
# Leave empty in production — swap the token store for a real secret manager.
GITHUB_TOKEN_STORE_PATH=./.data/github-tokens.json

# Optional overrides — useful for GitHub Enterprise Server.
# GITHUB_API_BASE_URL=https://api.github.com
# GITHUB_OAUTH_BASE_URL=https://github.com
# GITHUB_USER_AGENT=stackone-github-mcp/1.0

# --- StackOne (optional intermediary) -------------------------------------
# When STACKONE_API_KEY is set the StackOne adapter takes over; otherwise the
# server talks to api.github.com directly. The StackOne adapter still falls
# back to GitHub-direct for operations StackOne doesn't expose (e.g. search).
STACKONE_API_KEY=
STACKONE_ACCOUNT_ID=
STACKONE_BASE_URL=https://api.stackone.com
STACKONE_GITHUB_PROVIDER=github
